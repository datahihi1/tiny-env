{
    "name": "datahihi1/tiny-env",
    "description": "A simple environment variable loader for PHP applications",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Datahihi1\\TinyEnv\\": "src/"
        },
        "files": [
            "src/helper/helpers.php"
        ]
    },
    "authors": [
        {
            "name": "datahihi1",
            "email": "datahihi1100@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": ">=9.6",
        "phpstan/phpstan": ">=2.1",
        "symfony/var-dumper": ">=5.4"
    },
    "suggest": {
        "ext-bcmath": "For better integer overflow handling"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
