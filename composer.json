{
    "name": "datahihi1/tiny-env",
    "description": "A simple environment variable loader for PHP applications",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Datahihi1\\TinyEnv\\": "src/"
        },
        "files": [
            "src/helper/helpers.php"
        ]
    },
    "authors": [
        {
            "name": "datahihi1",
            "email": "datahihi1100@gmail.com"
        }
    ],
    "require": {
        "php": ">=7.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^7 || ^8 || ^9 || ^10 || ^11 || ^12 || ^13",
        "phpstan/phpstan": "^1 || ^2",
        "squizlabs/php_codesniffer": "^3 || ^4",
        "symfony/var-dumper": "^3 || ^4 || ^5 || ^6 || ^7 || ^8"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
