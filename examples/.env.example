# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=myapp
DB_USER=root
DB_PASS=secret

# App
APP_NAME=TinyEnv Demo
APP_DEBUG=true
APP_URL=http://localhost
API_KEY=aaabbb

# Variables for interpolation
DB_URL=${DB_HOST}:${DB_PORT}
USER_NAME=
USER=${USER_NAME:-guest}
ALT_USER=${USER_NAME-guest}

# Type examples
FEATURE_ENABLED=yes
FEATURE_DISABLED=no
MAX_USERS=100
PRICE=99.99
TAX_RATE=0.15
OPTIONAL_VAR=
NUM_STRING="/123/"
BOOL_STRING="/true/"

# API
API_BASE_URL=https://api.example.com
API_VERSION=v1
API_FULL_URL=${API_BASE_URL}/${API_VERSION}

# Require variable
REQUIRED_VAR=${REQUIRE_VAR?This variable is required but not set}